# ═══════════════════════════════════════════════════════════════════════════
# Voice-to-Notion Configuration
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# SCRIBERR CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
# Scriberr login credentials (set during first boot — worker auto-registers on fresh installs)
SCRIBERR_USERNAME=your_username
SCRIBERR_PASSWORD=your_password

# Scriberr URL (only needed for local/non-Docker usage — Docker sets this via docker-compose.yml)
SCRIBERR_API_URL=http://localhost:8080

# Port for Scriberr web UI (default: 8080)
SCRIBERR_PORT=8080

# Whisper model size: tiny, base, small, medium, large-v2, large-v3
# Larger = more accurate but slower. "small" is the best speed/quality tradeoff for English.
WHISPER_MODEL=small

# Device for transcription: cuda (NVIDIA), cpu, mps (Apple Silicon native only)
DEVICE=cpu

# Compute type: float32, int8 (faster on CPU, minimal accuracy loss)
COMPUTE_TYPE=int8

# Batch size: lower = less RAM, higher = faster with enough RAM. Default 16.
WHISPER_BATCH_SIZE=4

# ─────────────────────────────────────────────────────────────────────────────
# GROQ CLOUD TRANSCRIPTION (optional — much faster)
# ─────────────────────────────────────────────────────────────────────────────
# Get a free API key at https://console.groq.com/keys
# When set, the media pipeline uses Groq for transcription (~164x real-time)
# Falls back to local Scriberr on failure or when file exceeds 25MB
# Free tier: 8 hours of audio/day
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# NOTION CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
# Integration Token: https://www.notion.com/my-integrations
# Click "New Integration" → Copy "Internal Integration Secret"
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Database ID: From your database URL
# https://notion.so/WORKSPACE/DATABASE_ID?v=...
# Copy the DATABASE_ID part (32 characters, no hyphens)
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# WORKER CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
# How often to check Scriberr for completed jobs (seconds)
POLL_INTERVAL_SECONDS=30

# ─────────────────────────────────────────────────────────────────────────────
# MEDIA PIPELINE CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
# Enable/disable the media ingestion pipeline
ENABLE_MEDIA_PIPELINE=true

# How often to scan inbox_media/ for new URL files (seconds)
MEDIA_POLL_INTERVAL_SECONDS=15

# Audio output format: mp3, m4a, wav
AUDIO_FORMAT=mp3

# Host paths for media inbox/processed (bind mounts)
# Defaults to ./inbox_media and ./processed relative to docker-compose.yml
# MEDIA_INBOX_PATH=./inbox_media
# MEDIA_PROCESSED_PATH=./processed

# ─────────────────────────────────────────────────────────────────────────────
# TELEGRAM BOT (mobile capture layer)
# ─────────────────────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, paste token here
# When set, the worker starts a Telegram bot for mobile URL/voice/media capture
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# Comma-separated Telegram user IDs (get yours by messaging @userinfobot)
# Leave empty to allow all users (not recommended)
# TELEGRAM_ALLOWED_USERS=123456789

# ─── Webhook mode (recommended for always-on servers like Mac Mini) ──────
# Set WEBHOOK_DOMAIN to switch from long-polling to webhooks.
# Telegram pushes updates to your server instead of your server polling Telegram.
# Use with Cloudflare Tunnel: cloudflared tunnel --url http://localhost:3000
# WEBHOOK_DOMAIN=https://your-tunnel-subdomain.trycloudflare.com
# WEBHOOK_PORT=3000
# Optional: fixed secret path (auto-generated if not set)
# WEBHOOK_SECRET_PATH=/webhook/your-secret-here

# ─────────────────────────────────────────────────────────────────────────────
# GEMINI OCR (for photo/image text extraction via Telegram bot)
# ─────────────────────────────────────────────────────────────────────────────
# Get an API key at https://aistudio.google.com/apikey
# Used by the Telegram bot to OCR images sent as photos
# GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL: OLLAMA (Local LLM for summarization)
# ─────────────────────────────────────────────────────────────────────────────
# Uncomment these if you enable Ollama in docker-compose.yml
# ENABLE_SUMMARIZATION=true
# OLLAMA_BASE_URL=http://ollama:11434
# SUMMARY_MODEL=mistral
