{
  "name": "voice-to-notion",
  "version": "3.0.0",
  "description": "Self-hosted multi-format content capture to Notion/Obsidian. Voice, YouTube transcripts, articles, tweets, PDFs, and markdown -- with LLM auto-summarization.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:connection": "node scripts/test-connection.js",
    "ingest": "node scripts/ingest-url.js",
    "ingest-file": "node scripts/ingest-file.js"
  },
  "keywords": [
    "notion",
    "obsidian",
    "transcription",
    "summarization",
    "telegram",
    "yt-dlp",
    "groq",
    "llm",
    "capture",
    "knowledge-management"
  ],
  "author": "Truth Seeker Inc",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "enquirer": "^2.4.1",
    "fast-glob": "^3.3.3",
    "form-data": "^4.0.0",
    "telegraf": "^4.16.3",
    "jsdom": "^25.0.0",
    "@mozilla/readability": "^0.5.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
