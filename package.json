{
  "name": "voice-to-notion",
  "version": "2.0.0",
  "description": "Self-hosted voice/media transcription to Notion. Polls Scriberr for transcripts, ingests URLs via yt-dlp, extracts audio with ffmpeg, and syncs everything to Notion with audio file attachments.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "node scripts/test-connection.js",
    "ingest": "node scripts/ingest-url.js",
    "ingest-file": "node scripts/ingest-file.js"
  },
  "keywords": [
    "notion",
    "transcription",
    "scriberr",
    "voice",
    "audio",
    "whisper",
    "yt-dlp",
    "ffmpeg",
    "podcast"
  ],
  "author": "Truth Seeker Inc",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "enquirer": "^2.4.1",
    "fast-glob": "^3.3.3",
    "form-data": "^4.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
